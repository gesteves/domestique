# MCP Server Authentication
MCP_AUTH_TOKEN=your-secret-token-here

# Intervals.icu API (HTTP Basic Auth)
INTERVALS_API_KEY=your-intervals-api-key
INTERVALS_ATHLETE_ID=your-athlete-id

# Whoop API (OAuth 2.0)
WHOOP_CLIENT_ID=your-whoop-client-id
WHOOP_CLIENT_SECRET=your-whoop-client-secret

# TrainerRoad (iCalendar Feed URL)
TRAINERROAD_CALENDAR_URL=https://www.trainerroad.com/calendar/ical/your-private-token

# Google APIs (Weather API + Air Quality API + Pollen API + Elevation API)
# Forecast locations come from the athlete's Intervals.icu weather config.
# Enable the Weather API, Air Quality API, Pollen API, and Elevation API on your Google Cloud project:
# https://developers.google.com/maps/documentation/weather/get-api-key
# https://developers.google.com/maps/documentation/air-quality/get-api-key
# https://developers.google.com/maps/documentation/pollen/get-api-key
# https://developers.google.com/maps/documentation/elevation/cloud-setup
GOOGLE_API_KEY=your-google-api-key

# Last.fm (Optional)
# When both are set, get_workout_music and per-workout details include songs
# scrobbled during the workout. Create an API key at:
# https://www.last.fm/api/account/create
LASTFM_USERNAME=your-lastfm-username
LASTFM_API_KEY=your-lastfm-api-key

# Server Configuration
PORT=3000

# Error Reporting (Optional)
# Set to enable Bugsnag error reporting for upstream API failures
BUGSNAG_API_KEY=your-bugsnag-api-key

# Anthropic API (Optional)
# Enables two features when set:
#   - Claude Haiku categorization of TrainerRoad annotations into
#     Sick/Injured/Holiday/Note based on title + description (cached in
#     Redis when configured). Without this key, all TR annotations carry
#     category 'Note' and dedup against Intervals.icu uses title matching.
#   - Token counting in tool responses (development mode only).
ANTHROPIC_API_KEY=your-anthropic-api-key

# MCP Request Logging (Optional)
# When set to "true", logs each incoming JSON-RPC request to /mcp including
# the method, tool name (for tools/call), and any client-supplied _meta field.
# Useful for inspecting what different MCP clients (Claude, ChatGPT, etc.)
# send in _meta.
LOG_MCP_REQUESTS=false
