# MCP Server Authentication
MCP_AUTH_TOKEN=your-secret-token-here

# Intervals.icu API (HTTP Basic Auth)
INTERVALS_API_KEY=your-intervals-api-key
INTERVALS_ATHLETE_ID=your-athlete-id

# Whoop API (OAuth 2.0)
WHOOP_CLIENT_ID=your-whoop-client-id
WHOOP_CLIENT_SECRET=your-whoop-client-secret

# TrainerRoad (iCalendar Feed URL)
TRAINERROAD_CALENDAR_URL=https://www.trainerroad.com/calendar/ical/your-private-token

# Apple WeatherKit (all four required to enable daily forecasts)
# Forecast locations come from the athlete's Intervals.icu weather config
WEATHERKIT_KEY_ID=your-weatherkit-key-id
WEATHERKIT_TEAM_ID=your-apple-team-id
WEATHERKIT_SERVICE_ID=your-weatherkit-service-id
# Base64-encoded PEM contents of the .p8 private key, e.g. `base64 < AuthKey_XXXX.p8`
WEATHERKIT_PRIVATE_KEY=your-base64-encoded-p8-contents

# Server Configuration
PORT=3000

# Error Reporting (Optional)
# Set to enable Bugsnag error reporting for upstream API failures
BUGSNAG_API_KEY=your-bugsnag-api-key

# Debug (Optional - Development only)
# Used to count tokens in tool responses for development/testing
ANTHROPIC_API_KEY=your-anthropic-api-key

# MCP Request Logging (Optional)
# When set to "true", logs each incoming JSON-RPC request to /mcp including
# the method, tool name (for tools/call), and any client-supplied _meta field.
# Useful for inspecting what different MCP clients (Claude, ChatGPT, etc.)
# send in _meta.
LOG_MCP_REQUESTS=false
