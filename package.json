{
  "name": "domestique",
  "version": "1.0.0",
  "description": "Fitness MCP server integrating Intervals.icu, Whoop, and TrainerRoad",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && cp -r src/prompts dist/prompts",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "whoop:auth": "node dist/scripts/whoop-oauth.js",
    "whoop:auth:dev": "tsx src/scripts/whoop-oauth.ts",
    "whoop:backfill": "node dist/scripts/backfill-whoop-strain.js",
    "whoop:backfill:dev": "tsx src/scripts/backfill-whoop-strain.ts",
    "test:clients": "node dist/scripts/test-clients.js"
  },
  "keywords": [
    "mcp",
    "fitness",
    "intervals.icu",
    "whoop",
    "trainerroad"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@bugsnag/js": "^8.9.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chrono-node": "^2.9.1",
    "date-fns": "^4.3.0",
    "date-fns-tz": "^3.2.0",
    "express": "^5.2.1",
    "node-ical": "^0.26.1",
    "redis": "^5.12.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.8.0",
    "@vitest/coverage-v8": "^4.1.6",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.0.16"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
